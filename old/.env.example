# ─── Banco de Dados MySQL (Hostinger) ────────────────────────────────────────
DB_HOST=mysql.hostinger.com
DB_PORT=3306
DB_USER=seu_usuario_mysql
DB_PASSWORD=sua_senha_mysql
DB_NAME=nome_do_banco

# ─── Autenticação ─────────────────────────────────────────────────────────────
# Gere uma chave segura: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=troque-por-uma-chave-longa-e-aleatoria
ADMIN_PASSWORD=beraldo2025

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=3000

# ─── CORS (domínio do site na Hostinger) ──────────────────────────────────────
# Coloque o domínio exato após o deploy na Hostinger
ALLOWED_ORIGIN=https://www.seudominio.com.br
