# ── Segurança ────────────────────────────────────────────────
Options -Indexes

# Bloqueia acesso direto ao .env
<Files .env>
    Order allow,deny
    Deny from all
</Files>

# ── Rewrite Engine ───────────────────────────────────────────
RewriteEngine On

# Não reescreve arquivos/pastas que existem fisicamente
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# ── Rotas da API ─────────────────────────────────────────────

# POST /api/auth/login
RewriteRule ^api/auth(/login)?/?$ api/auth.php [QSA,L]

# GET|POST /api/noticias  /  GET|PUT|DELETE /api/noticias/5
RewriteRule ^api/noticias/([0-9]+)/?$ api/noticias.php?id=$1 [QSA,L]
RewriteRule ^api/noticias/?$          api/noticias.php       [QSA,L]

# GET|POST /api/projetos  /  GET|PUT|DELETE /api/projetos/5
RewriteRule ^api/projetos/([0-9]+)/?$ api/projetos.php?id=$1 [QSA,L]
RewriteRule ^api/projetos/?$          api/projetos.php       [QSA,L]

# GET /api/status
RewriteRule ^api/status/?$ api/status.php [QSA,L]
